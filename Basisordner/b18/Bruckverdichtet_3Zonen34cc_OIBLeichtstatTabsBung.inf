*--------------------------------------------------------------------------------
OUTPUTS
 TRANSFER : TIMEBASE=1.000
 AIRNODES = ZONE1 ZONE2 ZONE3 
 NTYPES =   1 : TAIR - air temperature of airnode
        =   9 : RELHUM - relativ humidity of airnode air
        =  29 : ABSHUM - absolute humidity of airnode air
        =  30 : QHEAT - sensible heating demand of airnode (positive values)
        =  31 : QCOOL - sensible cooling demand of airnode (positive values)
        =   4 : QINF - sensible infiltration energy gain of airnode
        =   5 : QVENT - sensible ventilation energy gain of airnode
        =   6 : QCOUP - sensible coupling energy gain of airnode
        =  12 : QSOLTR - total shortwave solar radiation transmitted through external windows of airnode (but not kept 100 % in airnode)
        =  98 : QDEHUM - latent energy demand of airnode by dehumidification (positive values)
        =  99 : QHUM - latent energy demand of airnode by humidification (positive values)
        =  25 : TOP - obsolete use new comfort outputs (Version 16: Operative temperature)
        =  62 : PMV - obsolete use new comfort outputs (Version 16: Predicted mean vote)
        =  63 : PPD - obsolete use new comfort outputs (Version 16: Percentage of person dissatisfied)
 AIRNODES = ZONE1 
 NTYPES =  28 : SCHEDULE = WORKDAY, WORKDAYHALLE, USE, WOHNWOCHE, WNATLUFT, NATLUFT, LUFT, WLUFT, WEEKEND, DAYNIGHT, ARBEIT, FREI, WOCHE, WRESTAURANTE, WVERANSTALTUNG, WSEMINAR, BTA_WEEK, WKUECHE, WSCHLAFT,  : - - values of all schedules
 AIRNODES = ZONE1 ZONE2 ZONE3 
 NTYPES = 901 : BAL_1 - solar balance for all zones
        = 902 : BAL_2 - solar balance for a sum of zones
        = 904 : BAL_4 - energy balance for all zones
        = 905 : BAL_5 - energy balance for a sum of zones
        = 907 : BAL_7 - moisture balance for all airnodes
        = 908 : BAL_8 - moisture balance for a sum of airnodes
