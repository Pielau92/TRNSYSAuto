Qh4 = [56,166]/3.6/Anutz4*(1-BTAmodellein)-BTAmodellein*(Qalfl4u)*heizperiode1      ![W/m2]

Qc1 = [56,13]/3.6/Anutz1*(1-BTAmodellein)+BTAmodellein*Qalfl1u*(1-heizperiode1)		![W/m2]
Qc2 = [56,14]/3.6/Anutz2*(1-BTAmodellein)+BTAmodellein*Qalfl2u*(1-heizperiode1)		![W/m2]
Qc3 = [56,15]/3.6/Anutz3*(1-BTAmodellein)+BTAmodellein*Qalfl3u*(1-heizperiode1)		![W/m2]
Qc4 = [56,167]/3.6/Anutz4*(1-BTAmodellein)+BTAmodellein*Qalfl4u*(1-heizperiode1) 	![W/m2]

