qvolgesh = (1-somm)*gt(TZU,TZU22w)*(TZU-TZU22w)*1.204*1.012/3.6*ventvolges/anutzges	![W/m2]
qvolgesc = (somm)*lt(TZU,TZU22s)*(TZU22s-TZU)*1.204*1.012/3.6*ventvolges/anutzges	![W/m2]

deltaabszu = somm*gt(abswrg,abshumgrenzo)*(abswrg-abshumgrenzo)+(1-somm)*lt(abswrg,abshumgrenzu)*(abshumgrenzu-abswrg)	![g/kg] falls Entfeuchtung im Sommer verwendet berechnet die Differenz zur Grenze, bzw. falls Befeuchtung im Winter
absENTFges = somm*ventvolges*1.204*deltaabszu			![kg] gesamt der Enteuchtungs Differenz
Qventfges = ne(abszu,absa)*694*(absENTFges)/anutzges	![W/m2] Verdampfungsenthalpie = 2500 kJ/kg H20 / 3,6 = 694 Wh/kg
absBEFges = (1-somm)*ventvolges*1.204*deltaabszu		![kg] gesamt der Befeuchtungs Differenz
Qvbefges = ne(abszu,absa)*694*(absBEFges)/anutzges		![W/m2] Verdampfungsenthalpie = 2500 kJ/kg H20 / 3,6 = 694 Wh/kg

qcges = (qc1*anutz1+qc2*anutz2+qc3*anutz3+qc4*anutz4)/(anutzges)					![W/m2]
qentfgesraum = (qentf1*anutz1+qentf2*anutz2+qentf3*anutz3+qentf4*anutz4)/(anutzges)	![W/m2]
qkuehlsens = qvolgesc+qcges	![W/m2]
qkuehlges = qvolgesc+Qventfges+qcges+qentfgesraum					![W/m2]
qhges = (qh1*anutz1+qh2*anutz2+qh3*anutz3+qh4*anutz4)/(anutzges) 	![W/m2]
qbefgesraum = (qbef1*anutz1+qbef2*anutz2+qbef3*anutz3+qbef4*anutz4)/(anutzges)	![W/m2] 
qheizsens = qvolgesh+qhges	![W/m2]
qheizges = qvolgesh+Qvbefges+qhges+qbefgesraum	![W/m2]
