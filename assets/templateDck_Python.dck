tsifennord3 = [56,143]	![deg C]
tsiwwest4 = [56,136]  	![deg C] muss angepasst werden, aktuell von Zone3
tsiwost4 = [56,137]		![deg C] muss angepasst werden, aktuell von Zone3
tsiwnord4 = [56,138]	![deg C] muss angepasst werden, aktuell von Zone3
tsibod4 = [56,139]		![deg C] muss angepasst werden, aktuell von Zone3
tsidec4 = [56,140]		![deg C] muss angepasst werden, aktuell von Zone3
tsiwsued4 = [56,141]	![deg C] muss angepasst werden, aktuell von Zone3
tsi4iwsp = [56,142]		![deg C] muss angepasst werden, aktuell von Zone3
tsifennord4 = [56,143]	![deg C] muss angepasst werden, aktuell von Zone3

*Strahlungsasymmetrie
tsiglueckoben1 = 0*tsibod1+0.73*tsidec1+0.018*tsiwnord1+0.144*tsifensued1+0.026*tsiwsued1+0.041*tsiwwest1+0.041*tsiwost1		![deg C]
tsiglueckvertikal1 = 0.096*tsibod1+0.108*tsidec1+0*tsiwnord1+0.501*tsifensued1+0.245*tsiwsued1+0.025*tsiwwest1+0.025*tsiwost1	![deg C]
tsi7730oben1 = 0*tsibod1+0.555*tsidec1+0.038*tsiwnord1+0.196*tsifensued1+0.051*tsiwsued1+0.08*tsiwwest1+0.08*tsiwost1			![deg C]
tsi7730unten1 = 0.902*tsibod1+0*tsidec1+0.005*tsiwnord1+0.0*tsifensued1+0.069*tsiwsued1+0.012*tsiwwest1+0.012*tsiwost1			![deg C]
deltatsiglueck1 = tsiglueckoben1-tsiglueckvertikal1	![K]
deltatsi77301 = tsi7730oben1-tsi7730unten1			![K]

tsiglueckoben2 = 0*tsibod2+0.73*tsidec2+0.018*tsiwnord2+0.144*tsifenwest2+0.026*tsiwsued2+0.041*tsiwwest2+0.041*tsiwost2		![deg C]
tsiglueckvertikal2 = 0.096*tsibod2+0.108*tsidec2+0*tsiwnord2+0.501*tsifenwest2+0.245*tsiwsued2+0.025*tsiwwest2+0.025*tsiwost2	![deg C]
tsi7730oben2 = 0*tsibod2+0.555*tsidec2+0.038*tsiwnord2+0.196*tsifenwest2+0.051*tsiwsued2+0.08*tsiwwest2+0.08*tsiwost2			![deg C]
tsi7730unten2 = 0.902*tsibod2+0*tsidec2+0.005*tsiwnord2+0.0*tsifenwest2+0.069*tsiwsued2+0.012*tsiwwest2+0.012*tsiwost2			![deg C]
deltatsiglueck2 = tsiglueckoben2-tsiglueckvertikal2	![K]
deltatsi77302 = tsi7730oben2-tsi7730unten2			![K]

tsiglueckoben3 = 0*tsibod3+0.73*tsidec3+0.018*tsiwsued3+0.144*tsifennord3+0.026*tsiwnord3+0.041*tsiwwest3+0.041*tsiwost3		![deg C]
tsiglueckvertikal3 = 0.096*tsibod3+0.108*tsidec3+0*tsiwsued3+0.501*tsifennord3+0.245*tsiwnord3+0.025*tsiwwest3+0.025*tsiwost3	![deg C]
tsi7730oben3 = 0*tsibod3+0.555*tsidec3+0.038*tsiwsued3+0.196*tsifennord3+0.051*tsiwnord3+0.08*tsiwwest3+0.08*tsiwost3			![deg C]
tsi7730unten3 = 0.902*tsibod3+0*tsidec3+0.005*tsiwsued3+0.0*tsifennord3+0.069*tsiwnord3+0.012*tsiwwest3+0.012*tsiwost3			![deg C]
deltatsiglueck3 = tsiglueckoben3-tsiglueckvertikal3	![K]
deltatsi77303 = tsi7730oben3-tsi7730unten3			![K]

tsiglueckoben4 = 0*tsibod4+0.73*tsidec4+0.018*tsiwsued4+0.144*tsifennord4+0.026*tsiwnord4+0.041*tsiwwest4+0.041*tsiwost4 		![deg C]
tsiglueckvertikal4 = 0.096*tsibod4+0.108*tsidec4+0*tsiwsued4+0.501*tsifennord4+0.245*tsiwnord4+0.025*tsiwwest4+0.025*tsiwost4 	![deg C]
tsi7730oben4 = 0*tsibod4+0.555*tsidec4+0.038*tsiwsued4+0.196*tsifennord4+0.051*tsiwnord4+0.08*tsiwwest4+0.08*tsiwost4 			![deg C]
tsi7730unten4 = 0.902*tsibod4+0*tsidec4+0.005*tsiwsued4+0.0*tsifennord4+0.069*tsiwnord4+0.012*tsiwwest4+0.012*tsiwost4 			![deg C]
deltatsiglueck4 = tsiglueckoben4-tsiglueckvertikal4	![K]
deltatsi77304 = tsi7730oben4-tsi7730unten4 			![K]

*-------------------------------------------------------------------------------------
* EQUATIONS "Qend/PEB je Zone"
*
EQUATIONS 74

PEBkonvel = 1.91	![-]
PEBkonvwae = 1.23	![-]

Qel1 = QelHH*anutz1/anutzges	![W/m2] Geraete pro Haushalt Profil1 mit Beleuchtung ohne Hilfsstrom ohne Heizen/kuehlen
Qwwnutz1 = 12.75/0.8*1000/8760	![W/m2] WWprofil
QelAbw1 = comp1 !Qel1*0.8		![W/m2] Abwaerme von Haushaltsgeraeten
qhend1 = (qh1+qbef1)/0.9/2.5	![W/m2] Endenergiebedarf Heizen ohne Hilfstrom 
qwwend1 = Qwwnutz1/0.7/2.5		![W/m2] Endenergiebedarf Warmwasser
qendwaerme1 = 0*qhend1+0*qwwend1	![W/m2] Achtung, hier nur, wenn nicht mit Strom direkt oder WP
qcend1 = (qc1+qentf1)/0.9/2.5	![W/m2] Endenergie, Achtung hier ohne Entfeuchtung, waere noch zu ergaenzen
qelges1 = Qel1+qhend1*0.05+qwwend1*0.05+qcend1*0.05+qhend1+qwwend1+qcend1	![W/m2] Strombedarf inkl Hilfsstrom
PEBwaerme1 = -0*PEBkonvwae	![W/m2] Hier wenn Waerme ueber Systemgrenze
PEBel1 = -qelges1*PEBkonvel	![W/m2] Primaerenergiebedarf gesamt
PVprod1 = qpvmm*0.18*0.85	![W/m2] Solarstromproduktion AC naeherungsweise Anteil von Nutzungflaeche mal 90%
Qeleigen1 = lt(PVprod1,qelges1)*PVprod1+(1-lt(PVprod1,qelges1))*qelges1	![W/m2]
Qelnetz1 = lt(PVprod1,qelges1)*(qelges1-PVprod1)	![W/m2] Netzbezug
Qelueberschuss1 = (1-lt(PVprod1,qelges1))*(PVprod1-qelges1)	![W/m2]
PEBelnetz1 = -Qelnetz1*PEBkonvel	![W/m2] Primaerenrgienetzstrom Netzstrom in system
PEBelueberschuss1 = Qelueberschuss1*PEBkonvel	![W/m2] Ueberschuss primaerenergetisch 
PEB1 = PEBwaerme1+PEBelnetz1+PEBelueberschuss1	![W/m2] Gesamter primaerenergiesaldo
PEB1akkum = [17,1]/1000*step	![W/m2]

Qel2 = QelHH*anutz2/anutzges	![W/m2] Geraete pro Haushalt Profil1 mit Beleuchtung ohne Hilfsstrom ohne Heizen/kuehlen
Qwwnutz2 = 12.75/0.8*1000/8760	![W/m2] WWprofil 
QelAbw2 = comp2					![W/m2] Abwaerme von Haushaltsgeraeten
qhend2 = (qh2+qbef2)/0.9/2.5	![W/m2] Endenergiebedarf Heizen ohne hilfstrom
qwwend2 = Qwwnutz2/0.7/2.5		![W/m2] Endenergiebedarf Warmwasser
qendwaerme2 = 0*qhend2+0*qwwend2	![W/m2] Achtung, hier nur, wenn nicht mit Strom direkt oder WP
qcend2 = (qc2+qentf2)/0.9/2.5	![W/m2] Endenergie
qelges2 = Qel2+qhend2*0.05+qwwend2*0.05+qcend2*0.05+qhend2+qwwend2+qcend2	![W/m2] Strombedarf inkl hilfsstrom 
PEBwaerme2 = -0*PEBkonvwae		![W/m2] Hier wenn Waerme ueber Systemgrenze
PEBel2 = -qelges2*PEBkonvel		![W/m2] Primaerenergiebedarf gesamt
PVprod2 = qpvmm*0.18*0.85		![W/m2] Solarstromproduktion AC naeherungsweise Anteil von Nutzungflaeche mal 90%
Qeleigen2 = lt(PVprod2,qelges2)*PVprod2+(1-lt(PVprod2,qelges2))*qelges2	![W/m2]
Qelnetz2 = lt(PVprod2,qelges2)*(qelges2-PVprod2) ![W/m2] Netzbezug
Qelueberschuss2 = (1-lt(PVprod2,qelges2))*(PVprod2-qelges2)	![W/m2] Netzbezug
PEBelnetz2 = -Qelnetz2*PEBkonvel	![W/m2] primaerenrgienetzstrom Netzstrom in system
PEBelueberschuss2 = Qelueberschuss2*PEBkonvel		![W/m2] Ueberschuss primaerenergetisch
PEB2 = PEBwaerme2+PEBelnetz2+PEBelueberschuss2	![W/m2] Gesamter primaerenergiesaldo 
PEB2akkum = [17,2]/1000*step	![W/m2]

Qel3 = QelHH*anutz3/anutzges	![W/m2] Geraete pro Haushalt Profil1 mit Beleuchtung ohne Hilfsstrom ohne Heizen/kuehlen
Qwwnutz3 = 12.75/0.8*1000/8760	![W/m2] WWprofil 
QelAbw3 = comp3  !Qel3*0.8		![W/m2] Abwaerme von Haushaltsgeraeten
qhend3 = (qh3+qbef3)/0.9/2.5	![W/m2] Endenergiebedarf Heizen ohne hilfstrom
qwwend3 = Qwwnutz3/0.7/2.5		![W/m2] Endenergiebedarf Warmwasser
qendwaerme3 = 0*qhend3+0*qwwend3	![W/m2] Achtung, hier nur, wenn nicht mit Strom direkt oder WP
qcend3 = (qc3+qentf3)/0.9/2.5	![W/m2] Endenergie
qelges3 = (Qel3+qentf3)+qhend3*0.05+qwwend3*0.05+qcend3*0.05+qhend3+qwwend3+qcend3	![W/m2] Strombedarf inkl hilfsstrom
PEBwaerme3 = -0*PEBkonvwae		![W/m2] Hier wenn Waerme ueber Systemgrenze
PEBel3 = -qelges3*PEBkonvel		![W/m2] Primaerenergiebedarf gesamt 
PVprod3 = qpvmm*0.18*0.85		![W/m2] Solarstromproduktion AC naeherungsweise Anteil von Nutzungflaeche mal 90%
Qeleigen3 = lt(PVprod3,qelges3)*PVprod3+(1-lt(PVprod3,qelges3))*qelges3	![W/m2]
Qelnetz3 = lt(PVprod3,qelges3)*(qelges3-PVprod3)	![W/m2] netzbezug
Qelueberschuss3 = (1-lt(PVprod3,qelges3))*(PVprod3-qelges3)	![W/m2]
PEBelnetz3 = -Qelnetz3*PEBkonvel	![W/m2] primaerenrgienetzstrom Netzstrom in system
PEBelueberschuss3 = Qelueberschuss3*PEBkonvel		![W/m2] Ueberschuss primaerenergetisch 
PEB3 = PEBwaerme3+PEBelnetz3+PEBelueberschuss3	![W/m2] Gesamter primaerenergiesaldo
PEB3akkum = [17,3]/1000*step	![W/m2]

Qel4 = QelHH*anutz4/anutzges	![W/m2] Geraete pro Haushalt Profil1 mit Beleuchtung ohne Hilfsstrom ohne Heizen/kuehlen 
Qwwnutz4 = 12.75/0.8*1000/8760	![W/m2] WWprofil 
QelAbw4 = comp4  				![W/m2] Abwaerme von Haushaltsgeraeten 
qhend4 = (qh4+qbef4)/0.9/2.5	![W/m2] Endenergiebedarf Heizen ohne hilfstrom 
qwwend4 = Qwwnutz4/0.7/2.5		![W/m2] Endenergiebedarf Warmwasser 
qendwaerme4 = 0*qhend4+0*qwwend4	![W/m2] Achtung, hier nur, wenn nicht mit Strom direkt oder WP 
qcend4 = (qc4+qentf4)/0.9/2.5	![W/m2] Endenergie 
qelges4 = (Qel4+qentf4)+qhend4*0.05+qwwend4*0.05+qcend4*0.05+qhend4+qwwend4+qcend4	![W/m2] Strombedarf inkl hilfsstrom 
PEBwaerme4 = -0*PEBkonvwae		![W/m2] Hier wenn Waerme ueber Systemgrenze 
PEBel4 = -qelges4*PEBkonvel		![W/m2] Primaerenergiebedarf gesamt 
PVprod4 = qpvmm*0.18*0.85		![W/m2] Solarstromproduktion AC naeherungsweise Anteil von Nutzungflaeche mal 90%
Qeleigen4 = lt(PVprod4,qelges4)*PVprod4+(1-lt(PVprod4,qelges4))*qelges4	![W/m2]
Qelnetz4 = lt(PVprod4,qelges4)*(qelges4-PVprod4)	![W/m2] netzbezug
Qelueberschuss4 = (1-lt(PVprod4,qelges4))*(PVprod4-qelges4)	![W/m2]
PEBelnetz4 = -Qelnetz4*PEBkonvel	![W/m2] primaerenrgienetzstrom Netzstrom in system 
PEBelueberschuss4 = Qelueberschuss4*PEBkonvel		![W/m2] Ueberschuss primaerenergetisch 
PEB4 = PEBwaerme4+PEBelnetz4+PEBelueberschuss4	![W/m2] Gesamter primaerenergiesaldo 
PEB4akkum = [17,5]/1000*step	![W/m2]

*------------------------------------------------------------------------------
* EQUATIONS "outvent"
* 
EQUATIONS 32
Qvvc1 = -lt(Qvv1,0)*Qvv1	![W/m2]
Qvvc2 = -lt(Qvv2,0)*Qvv2	![W/m2]
Qvvc3 = -lt(Qvv3,0)*Qvv3	![W/m2]
Qvvc4 = -lt(Qvv4,0)*Qvv4	![W/m2]

Qvvh1 = gt(Qvv1,0)*Qvv1		![W/m2]
Qvvh2 = gt(Qvv2,0)*Qvv2		![W/m2]
Qvvh3 = gt(Qvv3,0)*Qvv3		![W/m2]
Qvvh4 = gt(Qvv4,0)*Qvv4		![W/m2]

Qvol1 = -(twrg1-tzu1)*1.204*1.012/3.6*VENT1*Vol1/Anutz1		![W/m2]
Qvol2 = -(twrg2-tzu2)*1.204*1.012/3.6*VENT2*Vol2/Anutz2		![W/m2]
Qvol3 = -(twrg3-tzu3)*1.204*1.012/3.6*VENT3*Vol3/Anutz3		![W/m2]
Qvol4 = -(twrg4-tzu4)*1.204*1.012/3.6*VENT4*Vol4/Anutz4		![W/m2]

Qvol1a = -(ta-tzu1)*1.204*1.012/3.6*VENT1*Vol1/Anutz1		![W/m2]
Qvol2a = -(ta-tzu2)*1.204*1.012/3.6*VENT2*Vol2/Anutz2		![W/m2]
Qvol3a = -(ta-tzu3)*1.204*1.012/3.6*VENT3*Vol3/Anutz3		![W/m2]
Qvol4a = -(ta-tzu4)*1.204*1.012/3.6*VENT4*Vol4/Anutz4		![W/m2]

Qvol1c = -lt(Qvol1,0)*Qvol1		![W/m2]
Qvol1h = (gt(Qvol1,0))*Qvol1	![W/m2]
Qvol2c = -lt(Qvol2,0)*Qvol2		![W/m2]
Qvol2h = (gt(Qvol2,0))*Qvol2	![W/m2]
Qvol3c = -lt(Qvol3,0)*Qvol3		![W/m2]
Qvol3h = (gt(Qvol3,0))*Qvol3	![W/m2]
Qvol4c = -lt(Qvol4,0)*Qvol4 	![W/m2]
Qvol4h = (gt(Qvol4,0))*Qvol4 	![W/m2]

Qvol1ac = -lt(Qvol1a,0)*Qvol1a	![W/m2]
Qvol1ah = (gt(Qvol1a,0))*Qvol1a	![W/m2]
Qvol2ac = -lt(Qvol2a,0)*Qvol2a	![W/m2]
Qvol2ah = (gt(Qvol2a,0))*Qvol2a	![W/m2]
Qvol3ac = -lt(Qvol3a,0)*Qvol3a	![W/m2]
Qvol3ah = (gt(Qvol3a,0))*Qvol3a	![W/m2]
Qvol4ac = -lt(Qvol4a,0)*Qvol4a 	![W/m2]
Qvol4ah = (gt(Qvol4a,0))*Qvol4a ![W/m2]

