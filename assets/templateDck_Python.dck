*------------------------------------------------------------------------------
* EQUATIONS "Schatt"
* 
EQUATIONS 30

schattzu = 0.75    			![-]
Schattschaltinnen = 1		![-]   
Schatti = 0  				![-]

Schatti1 = Schatti*schattschaltinnen	![-] BUILDING-INPUT
Schatti2 = Schatti*schattschaltinnen	![-] BUILDING-INPUT 
Schatti3 = Schatti*schattschaltinnen 	![-] BUILDING-INPUT
Schatti4 = Schatti*schattschaltinnen  	![-] BUILDING-INPUT

strahlungsgrenze = 200   ![W/m2]

windauf = 1		![-]

tschattcontr1 = [40,1]	![-]
tschattcontr2 = [41,1]	![-]
tschattcontr3 = [42,1]	![-]
tschattcontr4 = [43,1]	![-]

reschmutz = 1			![-]

Schatts1 = (1-(1-schattzu*windauf*(somm*gt(igs,strahlungsgrenze)+(1-somm)*tschattcontr1))*[333,1]*reschmutz)	![-] BUILDING-INPUT
Schattw1 = (1-(1-schattzu*windauf*(somm*gt(igw,strahlungsgrenze)+(1-somm)*tschattcontr1))*[333,1]*reschmutz)	![-] BUILDING-INPUT
Schattn1 = (1-(1-schattzu*windauf*(somm*gt(ign,strahlungsgrenze)+(1-somm)*tschattcontr1))*[333,1]*reschmutz)	![-] BUILDING-INPUT
Schatto1 = (1-(1-schattzu*windauf*(somm*gt(igo,strahlungsgrenze)+(1-somm)*tschattcontr1))*[333,1]*reschmutz)	![-] BUILDING-INPUT
Schatts2 = (1-(1-schattzu*windauf*(somm*gt(igs,strahlungsgrenze)+(1-somm)*tschattcontr2))*[333,1]*reschmutz)	![-] BUILDING-INPUT
Schattw2 = (1-(1-schattzu*windauf*(somm*gt(igw,strahlungsgrenze)+(1-somm)*tschattcontr2))*[333,1]*reschmutz)	![-] BUILDING-INPUT
Schattn2 = (1-(1-schattzu*windauf*(somm*gt(ign,strahlungsgrenze)+(1-somm)*tschattcontr2))*[333,1]*reschmutz)	![-] BUILDING-INPUT
Schatto2 = (1-(1-schattzu*windauf*(somm*gt(igo,strahlungsgrenze)+(1-somm)*tschattcontr2))*[333,1]*reschmutz)	![-] BUILDING-INPUT
Schatts3 = (1-(1-schattzu*windauf*(somm*gt(igs,strahlungsgrenze)+(1-somm)*tschattcontr3))*[333,1]*reschmutz)	![-] BUILDING-INPUT
Schattw3 = (1-(1-schattzu*windauf*(somm*gt(igw,strahlungsgrenze)+(1-somm)*tschattcontr3))*[333,1]*reschmutz)	![-] BUILDING-INPUT
Schattn3 = (1-(1-schattzu*windauf*(somm*gt(ign,strahlungsgrenze)+(1-somm)*tschattcontr3))*[333,1]*reschmutz)	![-] BUILDING-INPUT
Schatto3 = (1-(1-schattzu*windauf*(somm*gt(igo,strahlungsgrenze)+(1-somm)*tschattcontr3))*[333,1]*reschmutz)	![-] BUILDING-INPUT
Schatts4 = (1-(1-schattzu*windauf*(somm*gt(igs,strahlungsgrenze)+(1-somm)*tschattcontr4))*[333,1]*reschmutz)	![-] BUILDING-INPUT
Schattw4 = (1-(1-schattzu*windauf*(somm*gt(igw,strahlungsgrenze)+(1-somm)*tschattcontr4))*[333,1]*reschmutz)	![-] BUILDING-INPUT
Schattn4 = (1-(1-schattzu*windauf*(somm*gt(ign,strahlungsgrenze)+(1-somm)*tschattcontr4))*[333,1]*reschmutz)	![-] BUILDING-INPUT
Schatto4 = (1-(1-schattzu*windauf*(somm*gt(igo,strahlungsgrenze)+(1-somm)*tschattcontr4))*[333,1]*reschmutz)	![-] BUILDING-INPUT

*------------------------------------------------------------------------------
* EQUATIONS "Vent"
* 
EQUATIONS 46 

rholuft = 1.204		![kg/m3]
waermerueckg = 0 ![%]
quellluftfaktor = 1	![-]
luftvolpers = 30	![m^3/h]	35 hyg. minimum -   42

lueftvol1 = 40*quellluftfaktor	![m^3/h]
lueftvol2 = 40*quellluftfaktor	![m^3/h]
lueftvol3 = 40*quellluftfaktor	![m^3/h]
lueftvol4 = 40*quellluftfaktor	![m^3/h]

wluft = [3,76] 			![-]

ventvol1 = wluft*(lueftvol1*somm+(1-somm)*lueftvol1)	![m^3/h]
ventvol2 = wluft*(lueftvol2*somm+(1-somm)*lueftvol2)	![m^3/h]
ventvol3 = wluft*(lueftvol3*somm+(1-somm)*lueftvol3)	![m^3/h]
ventvol4 = wluft*(lueftvol4*somm+(1-somm)*lueftvol4)	![m^3/h]

ventvolges = ventvol1 + ventvol2 + ventvol3 + ventvol4	![m^3/h]
ventvolges1 = ventvol1 + ventvol2 + ventvol3 + ventvol4	![m^3/h]

ventab1 = wluft*lueftvol1	![m^3/h]
ventab2 = wluft*lueftvol2	![m^3/h]
ventab3 = wluft*lueftvol3	![m^3/h]
ventab4 = wluft*lueftvol4	![m^3/h]

VENT1 = Vent1var*wluft	![1/h] BUILDING-INPUT
VENT2 = Vent2var*wluft	![1/h] BUILDING-INPUT
VENT3 = Vent3var*wluft	![1/h] BUILDING-INPUT
VENT4 = Vent4var*wluft	![1/h] BUILDING-INPUT

tmittel1 = (TZone1+TZone2+TZone3+TZone4)/4	![deg C]

twtoutges1 = ventvol1*TZone1+ventvol2*TZone2+ventvol3*TZone3+ventvol4*TZone4	![???]	
twtoutges2 = 0	![???]
twtout = lt(ventvolges,0.1)*tmittel1+(1-lt(ventvolges,0.1))*(twtoutges1)/(ventvolges+0.001)	![deg C]

ventab14ges = ventvolges	![m^3/h]
ventabges = ventvolges		![m^3/h]

tminwint = twtout-1			![deg C] Minimum der Zulufttemperatur im Winter
tzuquellmin = twtout-2		![deg C]
tminsomm = twtout-1			![deg C] Minimum der Zulufttemperatur im Sommer
tewt = ta	![deg C]
twtwarm = 0	![deg C]

twrg1 = (tewt+waermerueckg*(tzone1-tewt))	![deg C] Ventilatorabwaerme nicht beruecksichtigt
twrg2 = (tewt+waermerueckg*(tzone2-tewt))	![deg C]
twrg3 = (tewt+waermerueckg*(tzone3-tewt))	![deg C]
twrg4 = (tewt+waermerueckg*(tzone4-tewt))	![deg C]

tzuschalt = [18,2]	![???]

TZU22w = twrg2		![deg C] Wohnnutzung mit fixer Bypassregelung, Quellluftsystem mit beschraenkter Zulufttemperatur  
TZU22s = ta 		![deg C] Wohnnutzung, sonst z.B. Quellluftsystem gt(ta,tminsomm)*(ta*lt(ta,26)+twrg2*(1-lt(ta,26)))+(1-gt(ta,tminsomm))*tminsomm
TZU = somm*(gt(tzu22s,tzukuehl)*tzukuehl+(1-gt(tzu22s,tzukuehl))*tzu22s)+(1-somm)*(lt(tzu22w,tzuheiz)*tzuheiz+(1-lt(tzu22w,tzuheiz))*tzu22w)	![deg C]

tzu1 = (1-somm)*twrg2+somm*ta  ![deg C] BUILDING-INPUT Einfache saisonale Regelung, keine Sommer WT Nutzung
tzu2 = (1-somm)*twrg2+somm*ta  ![deg C] BUILDING-INPUT
tzu3 = (1-somm)*twrg2+somm*ta  ![deg C] BUILDING-INPUT
tzu4 = (1-somm)*twrg2+somm*ta  ![deg C] BUILDING-INPUT

*------------------------------------------------------------------------------
* EQUATIONS "Ventfeu"
* 
EQUATIONS 17

wrgfeu = 0		![%]
BeFeucht = 0	![%] Befeuchtung auf relative Feuchte von 	
EntFeucht = 0.1	![kg/kg] Entfeuchtung auf absolute Feuchte von
abshuma = absa	![kg/kg]
absoutges1 = ventvol1*absh1+ventvol2*absh2+ventvol3*absh3+ventvol4*absh4	![???]
absoutges2 = 0	![???]
abshumout = (absoutges1)/(ventvolges+0.001)	![kg/kg] abs Feuchte des Raumes, wo abgesaugt wird
abswrg = somm*(gt(TZU22s,tzukuehl)*absZU22s+(1-gt(TZU22s,tzukuehl))*absZU22s)+(1-somm)*(lt(TZU22w,tzuheiz)*absZU22w+(1-lt(TZU22w,tzuheiz))*absZU22w)	![kg/kg]
abswrg1 = (abshuma+(abshumout-abshuma)*wrgfeu)	![kg/kg]
abszu = absa 	![kg/kg] Feuchterueckgewinnung ausgeschalten    somm*(gt(abswrg,abshumgrenzo)*abshumgrenzo+(1-gt(abswrg,abshumgrenzo))*abswrg)+(1-somm)*(abswrg)	! kg/kg Feuchte in den Raum,
absZU22w = abswrg1	![kg/kg]
absZU22s = gt(ta,tminsomm)*(absa*lt(ta,26)+abswrg1*(1-lt(ta,26)))+(1-gt(ta,tminsomm))*absa	![kg/kg]
relzu = [150,6]	![???] umrechung von abs Feuchte in relative Feuchte

abszu1 = abszu	![kg/kg] BUILDING-INPUT
abszu2 = abszu	![kg/kg] BUILDING-INPUT
abszu3 = abszu	![kg/kg] BUILDING-INPUT
abszu4 = abszu	![kg/kg] BUILDING-INPUT

*------------------------------------------------------------------------------
* EQUATIONS "Signale"
* 
EQUATIONS 9

WindPV = [131,11] ![MW] 2015 Hagenbrunn und Seyring
CO2_2015 = [131,13] ![g/kWh]
CO2_2050 = [131,14] ![g/kWh]
QBedarf_2050 = [131,18]	![???]
QWasPVWind_2050 = [131,15]+[131,16]+[131,17]	![???] 
QBiomasse_2050 = [131,20]		![???]
QGeothermie_2050 = [131,22]		![???]
QUeberschuss_2050 = [131,24]	![???]
QUnterschuss_2050 = [131,25]	![???]

*------------------------------------------------------------------------------
* EQUATIONS "BTA"
* 
EQUATIONS 27

area_BTA1 = anutz1*0.9	![m2] Achtung, hier tatsaechliche Flaechen einstellen, wenn bekannt (ansonsten "anutz1*0.9")
area_BTA2 = anutz2*0.9	![m2]
area_BTA3 = anutz3*0.9	![m2]
area_BTA4 = anutz3*0.9	![m2]

tbtasoll1 = (kuehlperiode1*tkuehlsollmin+heizperiode1*theizsollmin)*(1-gt(queber,0))+(kuehlperiode1*tkuehlsollmax+heizperiode1*theizsollmax)*gt(queber,0)	![deg C]
!tbtasoll > in "mpc_enabled.dck" (Py_ein) bzw. in "mpc_disabled.dck" (1-Py_ein) verschoben
tbtahys = kuehlperiode1*tbtahysges+heizperiode1*tbtahysges	![K]

queberh = anutzges*Qelnutzerueberschuss*JAZh*etaverth    						![W] thermische Energie in Raum
queberhPV = ge(queberh,qbtamax)*qbtamax+(1-ge(queberh,qbtamax))*(queberh)		![W]
queberhcost = lt(queberhPV,qbtamax)*(qbtamax-queberhPV)*costfunction			![W]
queberc = anutzges*Qelnutzerueberschuss*JAZc*etavertc							![W]
quebercPV = ge(queberc,qbtamaxs)*qbtamaxs+(1-ge(queberc,qbtamaxs))*(queberc)	![W]
queberccost = lt(quebercPV,qbtamaxs)*(qbtamaxs-quebercPV)*costfunction			![W]
queber = heizperiode1*(queberhPV+queberhcost)+(1-heizperiode1)*(quebercPV+queberccost)	![W]

tofl1u0 = [170,2]  ![deg C] Ruecklauftemperatur
tofl2u0 = [170,4]  ![deg C]
tofl3u0 = [170,6]  ![deg C]
tofl4u0 = [170,18] ![deg C]

tofl1o0 = [170,8]  ![deg C]
tofl2o0 = [170,10] ![deg C]
tofl3o0 = [170,12] ![deg C]
tofl4o0 = [170,20] ![deg C]

tnode1o = [56,161]  ![deg C] Temperatur Bauteilaktivierung
tnode1u = [56,162]  ![deg C]

MBTAspez = MBTAspezges  ![kg/m2h] 22 bei Fußbodenheizung, 16 bei BTA

tsystemw = qbtamax/(minbta1+minbta2+minbta3+minbta4+1)/4.18*3.6*(1-gt(queber,0))+queber/(minbta1+minbta2+minbta3+minbta4+1)/4.18*3.6*gt(queber,0)+(tofl1u0*minbta1+tofl2u0*minbta2+tofl3u0*minbta3+tofl4u0*minbta4)/(minbta1+minbta2+minbta3+minbta4+0.001)	  ![deg C]
tsystems = -qbtamaxs/(minbta1+minbta2+minbta3+minbta4+1)/4.18*3.6*(1-gt(queber,0))-queber/(minbta1+minbta2+minbta3+minbta4+1)/4.18*3.6*gt(queber,0)+(tofl1u0*minbta1+tofl2u0*minbta2+tofl3u0*minbta3+tofl4u0*minbta4)/(minbta1+minbta2+minbta3+minbta4+0.001) ![deg C]	
tsystem1 = heizperiode1*tsystemw+(1-heizperiode1)*tsystems  ![deg C]

* TRNSYS-Python-Kopplung
INCLUDE "mpc_enabled.dck"

*------------------------------------------------------------------------------
* EQUATIONS "BTA/Qend/PEB"
*
EQUATIONS 67

tsystem = Qheizbtapy/((minbta1+0.0001)*(4.18/3.6))+tofl1u0	![deg C] Qheizbtapy in W, minbta1 in kg/h, Umrechnung Waermekapazitaet 4.18 kJ/kg K von Wasser in Wh/kg K

tinbta1v = qbtamax1/MBTAspez/4.18*3.6*(1-gt(queber1,0))+qbtamax1/MBTAspez/4.18*3.6*gt(queber1,0)+tofl1u0  ![deg C]
tinbta2v = qbtamax2/MBTAspez/4.18*3.6*(1-gt(queber2,0))+qbtamax2/MBTAspez/4.18*3.6*gt(queber2,0)+tofl2u0  ![deg C]
tinbta3v = qbtamax3/MBTAspez/4.18*3.6*(1-gt(queber3,0))+qbtamax3/MBTAspez/4.18*3.6*gt(queber3,0)+tofl3u0  ![deg C]
tinbta4v = qbtamax4/MBTAspez/4.18*3.6*(1-gt(queber4,0))+qbtamax4/MBTAspez/4.18*3.6*gt(queber4,0)+tofl4u0  ![deg C] 

tinbta1 = tsystem  ![deg C] BUILDING-INPUT
tinbta2 = tsystem  ![deg C] BUILDING-INPUT
tinbta3 = tsystem  ![deg C] BUILDING-INPUT
tinbta4 = tsystem  ![deg C] BUILDING-INPUT

tinbta1ov = qbtamax1/MBTAspez/4.18*3.6*(1-gt(queber1,0))+qbtamax1/MBTAspez/4.18*3.6*gt(queber1,0)+tofl1o0  ![deg C]
tinbta2ov = qbtamax2/MBTAspez/4.18*3.6*(1-gt(queber2,0))+qbtamax2/MBTAspez/4.18*3.6*gt(queber2,0)+tofl2o0  ![deg C]
tinbta3ov = qbtamax3/MBTAspez/4.18*3.6*(1-gt(queber3,0))+qbtamax3/MBTAspez/4.18*3.6*gt(queber3,0)+tofl3o0  ![deg C]
tinbta4ov = qbtamax4/MBTAspez/4.18*3.6*(1-gt(queber4,0))+qbtamax4/MBTAspez/4.18*3.6*gt(queber4,0)+tofl4o0  ![deg C]

tinbtao1 = tsystem  ![deg C] BUILDING-INPUT
tinbtao2 = tsystem  ![deg C] BUILDING-INPUT
tinbtao3 = tsystem  ![deg C] BUILDING-INPUT
tinbtao4 = tsystem  ![deg C] BUILDING-INPUT

bta1schalt = heizperiode1*(1-[64,1])+kuehlperiode1*[64,1]	![-]
bta2schalt = heizperiode1*(1-[65,1])+kuehlperiode1*[65,1]	![-]
bta3schalt = heizperiode1*(1-[66,1])+kuehlperiode1*[66,1]	![-]
bta4schalt = heizperiode1*(1-[71,1])+kuehlperiode1*[71,1]	![-]

!minbta1 > in "mpc_enabled.dck" (Py_ein) bzw. in "mpc_disabled.dck" (1-Py_ein) verschoben
!minbta2 > in "mpc_enabled.dck" (Py_ein) bzw. in "mpc_disabled.dck" (1-Py_ein) verschoben
!minbta3 > in "mpc_enabled.dck" (Py_ein) bzw. in "mpc_disabled.dck" (1-Py_ein) verschoben
!minbta4 > in "mpc_enabled.dck" (Py_ein) bzw. in "mpc_disabled.dck" (1-Py_ein) verschoben

tbtareg1 = TZone1	![deg C]
tbtareg2 = TZone2	![deg C]
tbtareg3 = TZone3	![deg C]
tbtareg4 = TZone4	![deg C]

thsoll1 = tbtasoll+tbtahys	![deg C]
thsoll1l = tbtasoll			![deg C]
thsoll2 = tbtasoll+tbtahys	![deg C]
thsoll2l = tbtasoll			![deg C]
thsoll3 = tbtasoll+tbtahys	![deg C]
thsoll3l = tbtasoll			![deg C]
thsoll4 = tbtasoll+tbtahys	![deg C]
thsoll4l = tbtasoll			![deg C]

igm = (igs2+igw2+ign2+igo2)/4   ![W/m2] mittlere Einstrahlung auf PV-Module

Qel = Qelvar  			![W/m2] Geraete pro Haushalt Profil mit Beleuchtung ohne Hilfsstrom ohne Heizen/Kuehlen
Qwwnutz = Qwwnutzvar	![W/m2] WW-Profil
QelAbw = QelAbwvar		![W/m2] Abwaerme von Haushaltsgeraeten

qhend = (qhges)/(JAZh*etaverth)		![W/m2] Endenergiebedarf Heizen ohne hilfstrom
qwwend = Qwwnutz/etavertww/JAZww	![W/m2] Endenergiebedarf Warmwasser
qendwaerme = 0*qhend+0*qwwend  		![W/m2] Achtung, hier nur, wenn nicht mit Strom direkt oder WP
qcend = (qcges+qentfgesraum)/(JAZc*etavertc)	![W/m2] Endenergie
qelges = Qel+qhend+qwwend+qcend		![W/m2] Strombedarf inkl Hilfsstrom
PEBwaerme = -0*PEBkonvwae   		![W/m2] hier wenn Waerme ueber Systemgrenze
PEBel = -qelges*PEBkonvel 			![WPE/m2] Primaerenergiebedarf gesamt
PVprod = qpvmm*0.18*0.85 			![W/m2] Solarstromproduktion AC naeherungsweise Anteil von Nutzungflaeche mal 85%
Qelnutzereigen = lt(PVprod,qel)*PVprod+(1-lt(PVprod,qel))*qel	![W/m2]

Qelnutzernetz = lt(PVprod,qel)*(qel-PVprod)						![W/m2] Netzbezug
Qelnutzernetzcost = lt(PVprod,qel)*(qel-PVprod)*costfunction	![W/m2] Netzbezug bei Freigabesignal
Qelnutzerueberschuss = (1-lt(PVprod,qel))*(PVprod-qel)  		![W/m2] Ueberschuss nach PV-Nutzung

qhcstrom = heizperiode1*qhend+(1-heizperiode1)*qcend  																![W/m2] Umrechnung Heiz- oder Kuehlleistung in Strom
Qeleigenqhc = lt(Qelnutzerueberschuss,qhcstrom)*Qelnutzerueberschuss+(1-lt(Qelnutzerueberschuss,qhcstrom))*qhcstrom	![W/m2] 
Qelnetzhc = lt(Qelnutzerueberschuss,qhcstrom)*(qhcstrom-Qelnutzerueberschuss) 										![W/m2] Netzbezug
Qelnetzhccost = lt(Qelnutzerueberschuss,qhcstrom)*(qhcstrom-Qelnutzerueberschuss)*costfunction 						![W/m2] Netzbezug bei Freigabesignal
Qelueberschusshc = (1-lt(Qelnutzerueberschuss,qhcstrom))*(Qelnutzerueberschuss-qhcstrom)								![W/m2]
qstromrest = qwwend/JAZww																							![W/m2]
Qeleigenww = gt(SpeicherWW,0)*QelPVeigenm2+(1-gt(SpeicherWW,0))*(lt(Qelueberschusshc,qstromrest)*Qelueberschusshc+(1-lt(Qelueberschusshc,qstromrest))*qstromrest)	![W/m2]
Qelnetzww = gt(SpeicherWW,0)*Qelnetzwwm2+(1-gt(SpeicherWW,0))*(lt(Qelueberschusshc,qstromrest)*(qstromrest-Qelueberschusshc)) 									![W/m2] Netzbezug
Qelnetzwwcost = gt(SpeicherWW,0)*Qeleigenwwcostm2+(1-gt(SpeicherWW,0))*(lt(Qelueberschusshc,qstromrest)*(qstromrest-Qelueberschusshc)*costfunction)				![W/m2] Netzbezug bei Freigabesignal
Qelueberschussww = gt(SpeicherWW,0)*Qelueberschusswwm2+(1-gt(SpeicherWW,0))*((1-lt(Qelueberschusshc,qstromrest))*(Qelueberschusshc-qstromrest))					![W/m2]
Qeleigenges = Qeleigenww+Qeleigenqhc+Qelnutzereigen				![W/m2]
Qelnetzges = Qelnetzww+Qelnetzhc+Qelnutzernetz					![W/m2]
Qelnetzgescost = Qelnetzwwcost+Qelnetzhccost+Qelnutzernetzcost	![W/m2]
Qelueberschussges = Qelueberschussww								![W/m2]

PEBelnetz = -Qelnetzges*PEBkonvel 				![W/m2] Primaerenrgienetzstrom in System
PEBelueberschuss = Qelueberschussges*PEBkonvel 	![W/m2] Ueberschuss primaerenergetisch
PEB = PEBwaerme+PEBelnetz+PEBelueberschuss 		![W/m2] Gesamter primaerenergiesaldo
PEBakkum = [17,4]/1000*step	![W/m2]

*------------------------------------------------------------------------------
* EQUATIONS "Speicher"
*
EQUATIONS 82

tspeichmin = 60			![deg C]
tspeichmaxmin = 70		![deg C]
tspeichermaxmax = 90	![deg C]
Qww_Speichermax = Qww_Speichermaxvar	![kg] bzw. [Liter]
Qww_Speicherverlustspez = 1.3 			![W/K] 120 l Bioler Energy Systems
QWW_ges = Qwwnutz/etavertww*anutzges  	![W]  Warmwasserbedarf thermisch nach Speicher
tWW_Speicher_tminus1 = gt(time,0)*[170,16]+(1-gt(time,0))*tspeichmin  	![deg C] Temperatur des Speichers im vorigen Zeitschritt
Qww_Speicherverlust = Qww_Speicherverlustspez*(tWW_Speicher_tminus1-20)	![Wh]
tww_Speichertminus1incV = tWW_Speicher_tminus1-Qww_Speicherverlust*step/(Qww_Speichermax*4.18/3.6)	![deg C]
tWW_Speicher_t1 = tWW_Speichertminus1incV-QWW_ges*step/(Qww_Speichermax*4.18/3.6)					![Wh]
deltatWWmax0 = tspeichermaxmax-tWW_Speicher_t1   ![deg C]
qwwwpmax = qwwwpmaxvar  ![W/m2] thermisch
qwwwpmaxges = qwwwpmax*anutzges ![W]
qwwmaxladenstep = qwwwpmaxges*step  ![Wh]
deltatWWmaxladen = qwwmaxladenstep/(Qww_Speichermax*4.18/3.6)   ![K] maximal ladbar
deltatWWmax1 = lt(deltatWWmaxladen,deltatWWmax0)*deltatWWmaxladen+(1-lt(deltatWWmaxladen,deltatWWmax0))*deltatWWmax0  	![K] maximal ladbar
deltatWWmin0 = lt(tWW_Speicher_t1,tspeichmin)*(tspeichmin-tWW_Speicher_t1) 												![K] Temperaturdifferenz, die mindestens geladen werden muss
deltatWWmin1 = gt(deltatWWmin0,deltatWWmaxladen)*deltatWWmaxladen+(1-gt(deltatWWmin0,deltatWWmaxladen))*deltatWWmin0	![K] 

queberwwPV = Qelueberschusshc*JAZww*anutzges  ![W]
deltatueberwwPVmax = queberwwPV*step/(Qww_Speichermax*4.18/3.6)  ![K] maximale Temperaturerhoehung durch PV ohne Leistungs und Speicherbeschraenkung
deltatueberwwPV = gt(deltatueberwwPVmax,deltatWWmax1)*deltatWWmax1+(1-gt(deltatueberwwPVmax,deltatWWmax1))*deltatueberwwPVmax  ![K] max. Temperaturerhoehung durch PV tatsaechlich
deltatwwnachPVmax1 = deltatWWmax1-deltatueberwwPV  ![K] bleibt noch zu decken ueber Rest
QPVeigen = deltatueberwwPV/step*(Qww_Speichermax*4.18/3.6)  ![W] Leistung PV in Speicher
QelPVeigen = QPVeigen/JAZww	![W]

Qelueberschusswwges = Qelueberschusshc*anutzges-QelPVeigen	![W]
queberwwcost = qwwwpmaxges*costfunction						![W]
deltatueberwwcostmax = queberwwcost*step/(Qww_Speichermax*4.18/3.6)  ![K] maximale Temperaturerhoehung durch Netzsignal
deltatueberwwcost = gt(deltatueberwwcostmax,deltatwwnachPVmax1)*deltatwwnachPVmax1+(1-gt(deltatueberwwcostmax,deltatwwnachPVmax1))*deltatueberwwcostmax  ![K] max. Temperaturerhoehung durch Netzstrom bei Freigabesignal tatsaechlich
Qeigenwwcostges = deltatueberwwcost/step*(Qww_Speichermax*4.18/3.6)  ![W] Leistung Netzstrom bei Freigabesignal in Speicher
Qeleigenwwcostges = Qeigenwwcostges/JAZww	![W]
deltatwwueberPVundCost = deltatueberwwcost+deltatueberwwPV ![K] wurde gedeckt

deltatwwnetz = lt(deltatwwueberPVundCost,deltatWWmin1)*(deltatWWmin1-deltatwwueberPVundCost)	![K]
Qnetzwwges = deltatwwnetz/step*(Qww_Speichermax*4.18/3.6)	![W] thermische Leistung Netz in Speicher
Qelnetzwwges = Qnetzwwges/JAZww								![W]
tWW_Speicher_t = tWW_Speicher_t1+deltatwwueberPVundCost+deltatwwnetz	![deg C]
Qeleigenwwges = Qeleigenwwcostges+QelPVeigen				![W]
QWW_gesm2 = QWW_ges/anutzges								![W/m2]
Qww_Speicherverlustm2 = Qww_Speicherverlust/anutzges		![W/m2]

QPVeigenm2 = QelPVeigen/anutzges*JAZww						![W/m2]
QelPVeigenm2 = QelPVeigen/anutzges							![W/m2]
Qeigenwwcostm2 = Qeigenwwcostges/anutzges					![W/m2]
Qeleigenwwcostm2 = Qeleigenwwcostges/anutzges				![W/m2]
Qnetzwwm2 = Qnetzwwges/anutzges								![W/m2]
Qelnetzwwm2 = Qelnetzwwges/anutzges							![W/m2]
Qelueberschusswwm2 = Qelueberschusswwges/anutzges			![W/m2]
Qww_BedarfVerlustem2 = QWW_gesm2+Qww_Speicherverlustm2		![W/m2]
Qww_Deckungm2 = QPVeigenm2+Qeigenwwcostm2+Qnetzwwm2			![W/m2]
Qelww_Deckungm2 = QelPVeigenm2+Qeleigenwwcostm2+Qelnetzwwm2	![W/m2]

Strom_ges = Qel*anutzges		![W]
Strom_PV = PVprod*anutzges		![W]
Q_Speichermax = 5000 			![Wh]
Q_Speicher_tminus1 = [170,14]   ![Wh] Speicherladung 1 Zeitschritt frueher, type 93
Q_Speicher_t = lt(Strom_PV,Strom_ges)*(ge(Qmaxentladenstep,QbedarfminusPVStep)*(QSpeichertminus1incV-QbedarfminusPVStep/Ethaentladen)+(1-ge(Qmaxentladenstep,QbedarfminusPVStep))*0)+(1-lt(Strom_PV,Strom_ges))*(lt(QPVminusBedarfStep,Qmaxladenstep)*(QSpeichertminus1incV+QPVminusBedarfStep*Ethaladen)+(1-lt(QPVminusBedarfStep,Qmaxladenstep))*(Q_Speichermax))   ![Wh], Ladezustand, bezogen auf maximale Entladbarkeit (d.h. 0-Niveau muessen nicht 0 Wh sein)
Q_AusNetz = lt(Strom_PV,Strom_ges)*(1-ge(Qmaxentladenstep,QbedarfminusPVStep))*((QbedarfminusPVStep-Qmaxentladenstep))/step  ![W] Leistung, wird aus Netz bezogen
Q_UeberschussinsNetz = (1-lt(Strom_PV,Strom_ges))*(1-lt(QPVminusBedarfStep,deltaQmax1))*(QPVminusBedarf-Qmaxladen) ![W] Leistung, geht ins Netz
deltaQmax1 = Q_Speichermax-QSpeichertminus1incV   ![Wh]
QSpeichertminus1incV = (1-EthaVerlusStep)*Q_Speicher_tminus1  ![Wh] Energie

EthaVerlust = 0.1 						![-] %/100 Verlust pro Monat
EthaVerlusStep = EthaVerlust/720*step 	![-] %/100 Verlust pro Zeitschritt

QPVminusBedarf = (1-gt(Strom_ges,Strom_PV))*(Strom_PV-Strom_ges)	![W]
QBedarfminusPV = gt(Strom_ges,Strom_PV)*(Strom_ges-Strom_PV)  		![W]

Ethaladen = 0.95  	![-] %/100, bezogen auf die Energie, die in den Speicher eingespeist werden soll
Ethaentladen = 0.95	![-] %/100, bezogen auf die Energie, die dem Speicher entnommen wird

QPVminusBedarfStep = QPVminusBedarf*step	![Wh] 
QbedarfminusPVStep = QBedarfminusPV*step	![Wh]
Qmaxladenstep = deltaQmax1/Ethaladen		![Wh] max moegliche Energie nach Entladen aus Speicher
Qmaxladen = Qmaxladenstep/Step 				![W]
Qmaxentladenstep = QSpeichertminus1incV*Ethaentladen  ![Wh] maximal entladbare Energie, bezogen auf bereitgestellte Energie
Qmaxentladen = Qmaxentladenstep/step		![Wh]
Qdeckeneigendir = lt(Strom_PV,Strom_ges)*Strom_PV   +(1-lt(Strom_PV,Strom_ges))*Strom_ges	![W] Direktdeckung ohne Speicher
QUeberschussdir = lt(Strom_ges,Strom_PV)*(Strom_PV-Strom_ges)								![W] Ueberschuss nach Direktdeckung vor Batterieladen
QdeckenEigenspeicher = lt(Strom_PV,Strom_ges)*(ge(Qmaxentladenstep,QbedarfminusPVStep)*(QbedarfminusPV)+(1-ge(Qmaxentladenstep,QbedarfminusPVStep))*Qmaxentladen)	![W]
QVerlustSpeicher = (Q_Speicher_tminus1-QSpeichertminus1incV)/step	![W]
QVerlustLaden = (1-lt(Strom_PV,Strom_ges))*(lt(QPVminusBedarfStep,Qmaxladenstep)*(QPVminusBedarf)*(1-Ethaladen)+(1-lt(QPVminusBedarfStep,Qmaxladenstep))*(Qmaxladen) *(1-Ethaladen))	![W]
QVerlustEntladen = lt(Strom_PV,Strom_ges)*(ge(Qmaxentladenstep,QbedarfminusPVStep)*(QbedarfminusPV/Ethaentladen)*(1-Ethaentladen)+(1-ge(Qmaxentladenstep,QbedarfminusPVStep))*Qmaxentladen/Ethaentladen*(1-Ethaentladen))	![W]
Qdeckeneigendirm2 = Qdeckeneigendir/anutzges			![W/m2]
QUeberschussdirm2 = QUeberschussdir/anutzges			![W/m2]
QdeckenEigenspeicherm2 = QdeckenEigenspeicher/anutzges	![W/m2]
Q_UeberschussinsNetzm2 = Q_UeberschussinsNetz/anutzges	![W/m2]
Q_Speicher_tm2 = Q_Speicher_t/anutzges					![W/m2]
Qverlustges = QVerlustSpeicher+QVerlustLaden+QVerlustEntladen	![W]
Qverlustgesm2 = Qverlustges/anutzges					![W/m2]

