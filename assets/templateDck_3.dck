EQUATIONS 16
wrgfeu = 0	! [%]
BeFeucht = 0	!Befeuchtung auf relative Feuchte von ..% 	
EntFeucht = 0.1	!Entfeuchtung auf absolute Feuchte von ..kg/kg	
abshuma = absa
absoutges1 = ventvol1*absh1+ventvol2*absh2+ventvol3*absh3
absoutges2 = 0
abshumout = (absoutges1)/(ventvolges+0.001)	! [kg/kg] abs Feuchte des Raumes wo abgesaugt wird
abswrg = somm*(gt(TZU22s,tzukuehl)*absZU22s+(1-gt(TZU22s,tzukuehl))*absZU22s)+(1-somm)*(lt(TZU22w,tzuheiz)*absZU22w+(1-lt(TZU22w,tzuheiz))*absZU22w)
abswrg1 = (abshuma+(abshumout-abshuma)*wrgfeu)
abszu = absa ! Feuchterückgewinnung ausgeschalten    somm*(gt(abswrg,abshumgrenzo)*abshumgrenzo+(1-gt(abswrg,abshumgrenzo))*abswrg)+(1-somm)*(abswrg)	! kg/kg Feuchte in den Raum,
absZU22w = abswrg1
absZU22s = gt(ta,tminsomm)*(absa*lt(ta,26)+abswrg1*(1-lt(ta,26)))+(1-gt(ta,tminsomm))*absa
relzu = [150,6]	! umrechung von abs Feuchte in relative Feuchte
abszu1 = abszu
abszu2 = abszu
abszu3 = abszu

