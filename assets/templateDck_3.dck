* EQUATIONS "Schatt"
* 
EQUATIONS 25
*schattzu = 0.8*schattschaltaussen !0.90
*strahlungsgrenze = 150
strahlungglobal = igh
grenzschatt=30   !windgeschwindigkeit, bis zu welcher Sonnenschutz aussen zu bleiben kann
windfass=wind*3.6*0.8*1.8  ! Windgeschwindigkeit in m/s (meist 10 m Höhe) umgerechnet auf km/h mal Reduktion durch Umgebungsstruktur/Laibung/Umrechnung auf tatsächliche Höhe + 80% für Böhen (nach Lahme)
windauf=1 !lt(windfass,grenzschatt)
tschattcontr1 = [40,1]
tschattcontr2 = [41,1]
tschattcontr3 = [42,1]
reschmutz=1
Schatts1 = 0*impuls+(1-impuls)*(1-(1-schattzu*windauf*(somm*gt(igs, strahlungsgrenze)+(1-somm)*tschattcontr1))*[333,1]*reschmutz)
Schattw1 = 0*impuls+(1-impuls)*(1-(1-schattzu*windauf*(somm*gt(igw, strahlungsgrenze)+(1-somm)*tschattcontr1))*[333,1]*reschmutz)  
Schattn1 = 0*impuls+(1-impuls)*(1-(1-schattzu*windauf*(somm*gt(ign, strahlungsgrenze)+(1-somm)*tschattcontr1))*[333,1]*reschmutz)
Schatto1 = 0*impuls+(1-impuls)*(1-(1-schattzu*windauf*(somm*gt(igo, strahlungsgrenze)+(1-somm)*tschattcontr1))*[333,1]*reschmutz)
Schatts2 = 0*impuls+(1-impuls)*(1-(1-schattzu*windauf*(somm*gt(igs, strahlungsgrenze)+(1-somm)*tschattcontr2))*[333,1]*reschmutz)
Schattw2 = 0*impuls+(1-impuls)*(1-(1-schattzu*windauf*(somm*gt(igw, strahlungsgrenze)+(1-somm)*tschattcontr2))*[333,1]*reschmutz)
