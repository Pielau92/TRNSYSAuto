PEBelnetz3 = -Qelnetz3*PEBkonvel !primärenrgienetzstrom Netzstrom in system
PEBelüberschuss3 = Qelüberschuss3*PEBkonvel ! Überschuss primärenergetisch W/m˛
PEB3 = PEBwaerme3+PEBelnetz3+PEBelüberschuss3 !Gesamter primärenergiesaldo in W/m˛
PEB3akkum = [17,3]/1000*step


*$UNIT_NAME Energie
*$LAYER Main
*$POSITION 349 511
*------------------------------------------------------------------------------


* EQUATIONS "outvent"
* 
EQUATIONS 24
Qvvc1 = -lt(Qvv1,0)*Qvv1
Qvvc2 = -lt(Qvv2,0)*Qvv2
Qvvc3 = -lt(Qvv3,0)*Qvv3

Qvvh1 = gt(Qvv1,0)*Qvv1
Qvvh2 = gt(Qvv2,0)*Qvv2
Qvvh3 = gt(Qvv3,0)*Qvv3
Qvol1 = -(twrg1-tzu1)*1.204*1.012/3.6*VENT1*Vol1/Anutz1
Qvol2 = -(twrg2-tzu2)*1.204*1.012/3.6*VENT2*Vol2/Anutz2
Qvol3 = -(twrg3-tzu3)*1.204*1.012/3.6*VENT3*Vol3/Anutz3
Qvol1a = -(ta-tzu1)*1.204*1.012/3.6*VENT1*Vol1/Anutz1
Qvol2a = -(ta-tzu2)*1.204*1.012/3.6*VENT2*Vol2/Anutz2
Qvol3a = -(ta-tzu3)*1.204*1.012/3.6*VENT3*Vol3/Anutz3
Qvol1c = -lt(Qvol1,0)*Qvol1
Qvol1h = (gt(Qvol1,0))*Qvol1
Qvol2c = -lt(Qvol2,0)*Qvol2
Qvol2h = (gt(Qvol2,0))*Qvol2
Qvol3c = -lt(Qvol3,0)*Qvol3
Qvol3h = (gt(Qvol3,0))*Qvol3
Qvol1ac = -lt(Qvol1a,0)*Qvol1a
Qvol1ah = (gt(Qvol1a,0))*Qvol1a
Qvol2ac = -lt(Qvol2a,0)*Qvol2a
Qvol2ah = (gt(Qvol2a,0))*Qvol2a
Qvol3ac = -lt(Qvol3a,0)*Qvol3a
Qvol3ah = (gt(Qvol3a,0))*Qvol3a
*$UNIT_NAME outvent
*$LAYER Main
*$POSITION 706 794

