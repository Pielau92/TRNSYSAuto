EQUATIONS 39 
rholuft = 1.204
waermerueckg = waermerueckgimpuls !0.85	! [%]
quellluftfaktor = 1	! [-] faktor
luftvolpers = 30		! [mł/h]	35 hyg. minimum -   42
lueftvol1 = 40*quellluftfaktor
lueftvol2 = 40*quellluftfaktor
lueftvol3 = 40*quellluftfaktor
ventvol1 = wluft*(lueftvol1*somm+(1-somm)*lueftvol1)	! [mł/h] 
ventvol2 = wluft*(lueftvol2*somm+(1-somm)*lueftvol2)
ventvol3 = wluft*(lueftvol3*somm+(1-somm)*lueftvol3)
ventvolges = ventvol1 + ventvol2 + ventvol3  
ventvolges1 =ventvol1 + ventvol2 + ventvol3  
ventab1 = wluft*lueftvol1
ventab2 = wluft*lueftvol2
ventab3 = wluft*lueftvol3
VENT1 = Vent1var*wluft ! 0.5 ! ventvol1/Vol1	! [1/h] -> Input Building
VENT2 = Vent2var*wluft !0. ! ventvol2/Vol2
VENT3 = Vent3var*wluft !0.5 ! ventvol3/Vol3
tmittel1 = (TZone1+TZone2+TZone3)/3
twtoutges1 = ventvol1*TZone1+ventvol2*TZone2+ventvol3*TZone3
twtoutges2 = 0
twtout = lt(ventvolges,0.1)*tmittel1+(1-lt(ventvolges,0.1))*(twtoutges1)/(ventvolges+0.001)
ventab14ges = ventvolges
ventabges = ventvolges
tminwint = twtout-1		! [C]	Minimum der Zulufttemperatur im Winter
tzuquellmin = twtout-2
tminsomm = twtout-1		! [C] Minimum der Zulufttemperatur im Sommer
tewt = ta ! EWT (Tewtphpp-Input65)*0.5
twtwarm = 0   !34
twrg1 = (tewt+waermerueckg*(tzone1-tewt))	! [C] Ventilatorabwärme nicht berücksichtigt
twrg2 = (tewt+waermerueckg*(tzone2-tewt))
twrg3 = (tewt+waermerueckg*(tzone3-tewt))
tzuschalt = [18,2]
TZU22w = twrg2       !Wohnnutzung mit fixer Bypassregelung, Quellluftsystem mit beschränkter Zulufttemperatur gt(twrg2,22)*22+(1-gt(twrg2,22))*twrg2  
TZU22s = ta !Wohnnutzung, sonst z.B. Quellluftsystem gt(ta,tminsomm)*(ta*lt(ta,26)+twrg2*(1-lt(ta,26)))+(1-gt(ta,tminsomm))*tminsomm
TZU = somm*(gt(tzu22s,tzukuehl)*tzukuehl+(1-gt(tzu22s,tzukuehl))*tzu22s)+(1-somm)*(lt(tzu22w,tzuheiz)*tzuheiz+(1-lt(tzu22w,tzuheiz))*tzu22w)
tzu1 = (1-somm)*twrg2+somm*ta  !Einfache saisonale Regelung, keine Sommer WT Nutzung
tzu2 = (1-somm)*twrg2+somm*ta  !Einfache saisonale Regelung, keine Sommer WT Nutzung
tzu3 = (1-somm)*twrg2+somm*ta  !Einfache saisonale Regelung, keine Sommer WT Nutzung
