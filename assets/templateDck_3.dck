tkuehlgesfb = 24*(1-BTAmodellein)+BTAmodellein*50 !25-wkuehlvor*1

Tkuehl1 = tkuehlges	! Solltemperaturen Kühlen [°C]	
Tkuehl2 = tkuehlges 
Tkuehl3 = tkuehlges 
mkuehl = 7     !Abbildung Verlauf Leistungsabgabe bei Flächenheizungen (meist in Abhängigkeit von Differenz Raumtemperatur zu BTA_Mitteltemperatur (Differenz Vorlauf / Rücklauf)
mkuehlfb = 4.4
dkuehl = 5
dkuehlfb = 0
mkuehlp = 6
dkuehlp = 0
ttau2 = [332,8]
ttau2grenz = ttau2+2
tkuehlvormit = lt(ttau2grenz,19)*19+(1-lt(ttau2grenz,19))*ttau2grenz
kfakreduk = 0.85 !Faktor für Flächenreduktion etc. global
kuehlmax1 = (-impuls*qbtamax1*(1-heizperiode1)+(1-impuls)*(1000*(1-GSC)+40.5*kuehlidealfrei*GSC))*anutz1 ! Anutz1*(mkuehlp*(TZone1-tkuehlvormit)+dkuehlp)*kfakreduk
kuehlmax2 = (-impuls*qbtamax2*(1-heizperiode1)+(1-impuls)*(1000*(1-GSC)+40.5*kuehlidealfrei*GSC))*anutz2 ! Anutz2*(mkuehlp*(TZone2-tkuehlvormit)+dkuehlp)*kfakreduk
kuehlmax3 = (-impuls*qbtamax3*(1-heizperiode1)+(1-impuls)*(1000*(1-GSC)+40.5*kuehlidealfrei*GSC))*anutz3 ! Anutz3*(mkuehlp*(TZone3-tkuehlvormit)+dkuehlp)*kfakreduk
*absmax = 0.012  !Grenze für ideale Entfeuchtung Raum
absmax1 = absmax
absmax2 = absmax
absmax3 = absmax


