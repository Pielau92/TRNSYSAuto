* EQUATIONS "BTA"
* 
EQUATIONS 83

tbtasollohneimpuls = (kuehlperiode1*tkuehlsollmin+heizperiode1*theizsollmin)*(1-gt(queber,0))+(kuehlperiode1*tkuehlsollmax+heizperiode1*theizsollmax)*gt(queber,0)
tbtasollmitimpuls = (kuehlperiode1*tkuehlsollmin+heizperiode1*theizsollmin)*(1-gt(queber1,0))+(kuehlperiode1*tkuehlsollmax+heizperiode1*theizsollmax)*gt(queber1,0)
tbtasoll = impuls*tbtasollmitimpuls+(1-impuls)*tbtasollohneimpuls
tbtahys = kuehlperiode1*tbtahysges+heizperiode1*tbtahysges

queberh= anutzges*Qelnutzerüberschuss*JAZh*etaverth    !gt(time,36)*lt(time,96)*50*anutzges  Thermische Energie in Raum
queberhPV=ge(queberh,qbtamax)*qbtamax+(1-ge(queberh,qbtamax))*(queberh)
queberhwind=lt(queberhPV,qbtamax)*(qbtamax-queberhPV)*WindstromvonAnlagen
queberc= anutzges*Qelnutzerüberschuss*JAZc*etavertc
quebercPV=ge(queberc,qbtamaxs)*qbtamaxs+(1-ge(queberc,qbtamaxs))*(queberc)
quebercwind=lt(quebercPV,qbtamaxs)*(qbtamaxs-quebercPV)*WindstromvonAnlagen
queber=heizperiode1*(queberhPV+queberhwind)+(1-heizperiode1)*(quebercPV+quebercwind)
tofl1u0=[170,2]
tofl2u0=[170,4]
tofl3u0=[170,6]
tofl1o0=[170,8]
tofl2o0=[170,10]
tofl3o0=[170,12]


MBTAspez = MBTAspezges  !kg/h/m˛ 22 bei fußbodenheizung, 16 bei BTA
tsystemw = qbtamax/(minbta1+minbta2+minbta3+1)/4.18*3.6*(1-gt(queber,0))+queber/(minbta1+minbta2+minbta3+1)/4.18*3.6*gt(queber,0)+(tofl1u0*minbta1+tofl2u0*minbta2+tofl3u0*minbta3)/(minbta1+minbta2+minbta3+0.001)
tsystems = -qbtamaxs/(minbta1+minbta2+minbta3+1)/4.18*3.6*(1-gt(queber,0))-queber/(minbta1+minbta2+minbta3+1)/4.18*3.6*gt(queber,0)+(tofl1u0*minbta1+tofl2u0*minbta2+tofl3u0*minbta3)/(minbta1+minbta2+minbta3+0.001)
tsystem1 = heizperiode1*tsystemw+(1-heizperiode1)*tsystems
tsystem = gt(tsystem1,35)*35+(1-gt(tsystem1,35))*(lt(tsystem1,18)*18+tsystem1*(1-lt(tsystem1,18)))
*tsystem = (tinbta1v*minbta1+tinbta2v*minbta2+tinbta3v*minbta3)/(minbta1+minbta2+minbta3+0.001) !30*heizperiode1+(1-heizperiode1)*20  !Außentemperatursteuern
tinbta1v = qbtamax1/MBTAspez/4.18*3.6*(1-gt(queber1,0))+qbtamax1/MBTAspez/4.18*3.6*gt(queber1,0)+tofl1u0  !tsystem
tinbta2v = qbtamax2/MBTAspez/4.18*3.6*(1-gt(queber2,0))+qbtamax2/MBTAspez/4.18*3.6*gt(queber2,0)+tofl2u0
tinbta3v = qbtamax3/MBTAspez/4.18*3.6*(1-gt(queber3,0))+qbtamax3/MBTAspez/4.18*3.6*gt(queber3,0)+tofl3u0
tinbta1=tinbta1v*impuls+(1-impuls)*tsystem
tinbta2=tinbta2v*impuls+(1-impuls)*tsystem
tinbta3=tinbta3v*impuls+(1-impuls)*tsystem
tinbta1ov = qbtamax1/MBTAspez/4.18*3.6*(1-gt(queber1,0))+qbtamax1/MBTAspez/4.18*3.6*gt(queber1,0)+tofl1o0  !tsystem
tinbta2ov = qbtamax2/MBTAspez/4.18*3.6*(1-gt(queber2,0))+qbtamax2/MBTAspez/4.18*3.6*gt(queber2,0)+tofl2o0
tinbta3ov = qbtamax3/MBTAspez/4.18*3.6*(1-gt(queber3,0))+qbtamax3/MBTAspez/4.18*3.6*gt(queber3,0)+tofl3o0
tinbtao1=tinbta1ov*impuls+(1-impuls)*tsystem !tsystem
tinbtao2=tinbta2ov*impuls+(1-impuls)*tsystem  !tinbta2ov !tsystem
tinbtao3=tinbta3ov*impuls+(1-impuls)*tsystem  !tinbta3ov !tsystem

bta1schalt=heizperiode1*(1-[64,1])+kuehlperiode1*[64,1]
bta2schalt=heizperiode1*(1-[65,1])+kuehlperiode1*[65,1]
bta3schalt=heizperiode1*(1-[66,1])+kuehlperiode1*[66,1]

minbta1 = BTAmodellein*MBTAspez*(anutz1*0.9)*((bta1schalt)*heizperiode1+bta1schalt*kuehlperiode1)*WBTA*B2Grid_frei  !Achtung, hier tatsächliche Flächen einstellen
minbta2 = BTAmodellein*MBTAspez*(anutz2*0.9)*((bta2schalt)*heizperiode1+bta2schalt*kuehlperiode1)*WBTA*B2Grid_frei
minbta3 = BTAmodellein*MBTAspez*(anutz3*0.9)*((bta3schalt)*heizperiode1+bta3schalt*kuehlperiode1)*WBTA*B2Grid_frei

tbtareg1 = TZone1
tbtareg2 = TZone2
tbtareg3 = TZone3


thsoll1=tbtasoll+tbtahys
thsoll1l=tbtasoll
*tcsoll1=tbtasoll+tbtahys	!v laut OENORM Kat. II
*tcsoll1l=tbtasoll
thsoll2=tbtasoll+tbtahys
thsoll2l=tbtasoll
thsoll3=tbtasoll+tbtahys
thsoll3l=tbtasoll

igm=(igs2+igw2+ign2+igo2)/4   !mittlere Einstrahlung auf PV-Module

Qel = Qelvar  !QelHH/4 !(Qel1*anutz1+Qel2*anutz2+Qel3*anutz3)/anutzges  !([3,44]+[3,45]+[3,46]+[3,47]+[3,48]+(licht3*anutz3)/1000+[3,50]+[3,51]+[3,52])*1000/anutz3 !Geräte pro Haushalt Profil1 mit Beleuchtung ohne Hilfsstrom ohne Heizen/kühlen in W/m˛
Qwwnutz = Qwwnutzvar !QWW_HH/4 !12.75/0.8*1000/8760 ![3,40]*1000/anutz3 !WWprofil in W/m˛
QelAbw = QelAbwvar !Qel*0.8 !QelabwHH !Qel*0.8 !Abwärme von Haushaltsgeräten in W/m˛
qhend = (qhges)/(JAZh*etaverth) !Endenergiebedarf Heizen ohne hilfstrom qhend = (qhges+qbefgesraum)/(JAZh*etaverth)
qwwend = Qwwnutz/etavertww/JAZww !Endenergiebedarf Warmwasser
qendwaerme=0*qhend+0*qwwend  !Achtung, hier nur, wenn nicht mit Strom direkt oder WP
qcend= (qcges+qentfgesraum)/(JAZc*etavertc)  !Endenergie
qelges = Qel+qhend+qwwend+qcend !Strombedarf inkl hilfsstrom W/m˛
PEBwaerme=-0*PEBkonvwae   !Hier wenn Wärme über Systemgrenze
PEBel = -qelges*PEBkonvel !Primärenergiebedarf gesamt PE/m˛
PVprod = qpvmm*0.18*0.85 !Solarstromproduktion AC näherungsweise Anteil von Nutzungfläche mal 85%, in W/m˛
Qelnutzereigen = lt(PVprod,qel)*PVprod+(1-lt(PVprod,qel))*qel

Qelnutzernetz = lt(PVprod,qel)*(qel-PVprod) !netzbezug in W/m˛
Qelnutzernetzwind = lt(PVprod,qel)*(qel-PVprod)*WindstromvonAnlagen !netzbezug in W/m˛
Qelnutzerüberschuss = (1-lt(PVprod,qel))*(PVprod-qel)  !Überschuss nach
qhcstrom=heizperiode1*qhend+(1-heizperiode1)*qcend  !Umrechnung Heiz- oder Kühlleistung in Strom
Qeleigenqhc = lt(Qelnutzerüberschuss,qhcstrom)*Qelnutzerüberschuss+(1-lt(Qelnutzerüberschuss,qhcstrom))*qhcstrom
Qelnetzhc = lt(Qelnutzerüberschuss,qhcstrom)*(qhcstrom-Qelnutzerüberschuss) !netzbezug in W/m˛
Qelnetzhcwind = lt(Qelnutzerüberschuss,qhcstrom)*(qhcstrom-Qelnutzerüberschuss)*WindstromvonAnlagen !netzbezug in W/m˛
Qelüberschusshc = (1-lt(Qelnutzerüberschuss,qhcstrom))*(Qelnutzerüberschuss-qhcstrom)
qstromrest=qwwend/JAZww
Qeleigenww = gt(SpeicherWW,0)*QelPVeigenm2+(1-gt(SpeicherWW,0))*(lt(Qelüberschusshc,qstromrest)*Qelüberschusshc+(1-lt(Qelüberschusshc,qstromrest))*qstromrest)
Qelnetzww = gt(SpeicherWW,0)*Qelnetzwwm2+(1-gt(SpeicherWW,0))*(lt(Qelüberschusshc,qstromrest)*(qstromrest-Qelüberschusshc)) !netzbezug in W/m˛
Qelnetzwwwind = gt(SpeicherWW,0)*Qeleigenwwwindm2+(1-gt(SpeicherWW,0))*(lt(Qelüberschusshc,qstromrest)*(qstromrest-Qelüberschusshc)*WindstromvonAnlagen) !netzbezug in W/m˛
Qelüberschussww = gt(SpeicherWW,0)*Qelueberschusswwm2+(1-gt(SpeicherWW,0))*((1-lt(Qelüberschusshc,qstromrest))*(Qelüberschusshc-qstromrest))
Qeleigenges=Qeleigenww+Qeleigenqhc+Qelnutzereigen
Qelnetzges=Qelnetzww+Qelnetzhc+Qelnutzernetz
Qelnetzgeswind=Qelnetzwwwind+Qelnetzhcwind+Qelnutzernetzwind
Qelüberschussges=Qelüberschussww

PEBelnetz = -Qelnetzges*PEBkonvel !primärenrgienetzstrom Netzstrom in system
PEBelüberschuss = Qelüberschussges*PEBkonvel ! Überschuss primärenergetisch W/m˛
PEB = PEBwaerme+PEBelnetz+PEBelüberschuss !Gesamter primärenergiesaldo in W/m˛
PEBakkum = [17,4]/1000*step

*$UNIT_NAME BTA
*$LAYER Main
*$POSITION -3 -6

UNIT 170 TYPE 93	 Type93
*$UNIT_NAME Type93
*$MODEL .\Utility\Input Value Recall\Type93.tmf
*$POSITION 45 34
*$LAYER Main # 
!TRACE START STOP
PARAMETERS 2
8		! 1 Number of inputs to be stored
2		! 2 Number of timesteps to be stored (including the curent step)
INPUTS 8
tofl1u tofl2u tofl3u tofl1o tofl2o tofl3o Q_Speicher_t tWW_Speicher_t		! [unconnected] Input value
*** INITIAL INPUT VALUES
21 21 21 21 21 21 0 50
*------------------------------------------------------------------------------
* EQUATIONS "speicher"

equations 82
tspeichmin=60
tspeichmaxmin=70
tspeichermaxmax=90
Qww_Speichermax=Qww_Speichermaxvar  !120*10  ! kg
Qww_Speicherverlustspez=1.3 !W/K 120 l Bioler Energy Systems
QWW_ges=Qwwnutz/etavertww*anutzges  !W  Warmwasserbedarf thermisch nach Speicher
tWW_Speicher_tminus1=gt(time,0)*[170,16]+(1-gt(time,0))*tspeichmin  !Temperatur des Speichers im vorigen Zeitschritt
Qww_Speicherverlust=Qww_Speicherverlustspez*(tWW_Speicher_tminus1-20)  !Wh
tww_Speichertminus1incV=tWW_Speicher_tminus1-Qww_Speicherverlust*step/(Qww_Speichermax*4.18/3.6) !°C
tWW_Speicher_t1=tWW_Speichertminus1incV-QWW_ges*step/(Qww_Speichermax*4.18/3.6) !Wh
deltatWWmax0 = tspeichermaxmax-tWW_Speicher_t1   !°C
qwwwpmax=qwwwpmaxvar  !W/m˛ thermisch
qwwwpmaxges=qwwwpmax*anutzges !W
qwwmaxladenstep=qwwwpmaxges*step  !Wh
deltatWWmaxladen= qwwmaxladenstep/(Qww_Speichermax*4.18/3.6)   !Wh maximal ladbar
deltatWWmax1=lt(deltatWWmaxladen,deltatWWmax0)*deltatWWmaxladen+(1-lt(deltatWWmaxladen,deltatWWmax0))*deltatWWmax0  !was ist maximal ladbar
deltatWWmin0 =lt(tWW_Speicher_t1,tspeichmin)*(tspeichmin-tWW_Speicher_t1) !Temperaturdifferenz, die mindestens geladen werden muss
deltatWWmin1 =gt(deltatWWmin0,deltatWWmaxladen)*deltatWWmaxladen+(1-gt(deltatWWmin0,deltatWWmaxladen))*deltatWWmin0

queberwwPV=Qelüberschusshc*JAZww*anutzges  !Leistung W
deltatueberwwPVmax=queberwwPV*step/(Qww_Speichermax*4.18/3.6)  !maximale Temperaturerhöhung durch PV ohne Leistungs und Speicherbeschränkung
deltatueberwwPV=gt(deltatueberwwPVmax,deltatWWmax1)*deltatWWmax1+(1-gt(deltatueberwwPVmax,deltatWWmax1))*deltatueberwwPVmax  !max. Temperaturerhöhung durch PV tatsächlich
deltatwwnachPVmax1=deltatWWmax1-deltatueberwwPV  !bleibt noch zu decken über Rest
QPVeigen=deltatueberwwPV/step*(Qww_Speichermax*4.18/3.6)  !Leistung PV in Speicher
QelPVeigen=QPVeigen/JAZww

Qelueberschusswwges=Qelüberschusshc*anutzges-QelPVeigen
queberwwwind=qwwwpmaxges*WindstromvonAnlagen
deltatueberwwwindmax=queberwwwind*step/(Qww_Speichermax*4.18/3.6)  !maximale Temperaturerhöhung durch Wind
deltatueberwwwind=gt(deltatueberwwwindmax,deltatwwnachPVmax1)*deltatwwnachPVmax1+(1-gt(deltatueberwwwindmax,deltatwwnachPVmax1))*deltatueberwwwindmax  !max. Temperaturerhöhung durch Wind tatsächlich
Qeigenwwwindges=deltatueberwwwind/step*(Qww_Speichermax*4.18/3.6)  !Leistung Wind in Speicher
Qeleigenwwwindges=Qeigenwwwindges/JAZww
deltatwwueberPVundWind=deltatueberwwwind+deltatueberwwPV !wurde gedeckt

deltatwwnetz=lt(deltatwwueberPVundWind,deltatWWmin1)*(deltatWWmin1-deltatwwueberPVundWind)
Qnetzwwges=deltatwwnetz/step*(Qww_Speichermax*4.18/3.6)  !thermische Leistung Netz in Speicher
Qelnetzwwges=Qnetzwwges/JAZww
tWW_Speicher_t=tWW_Speicher_t1+deltatwwueberPVundWind+deltatwwnetz
Qeleigenwwges=Qeleigenwwwindges+QelPVeigen
QWW_gesm2=QWW_ges/anutzges
Qww_Speicherverlustm2=Qww_Speicherverlust/anutzges

QPVeigenm2=QelPVeigen/anutzges*JAZww
QelPVeigenm2=QelPVeigen/anutzges
Qeigenwwwindm2=Qeigenwwwindges/anutzges
Qeleigenwwwindm2=Qeleigenwwwindges/anutzges
Qnetzwwm2=Qnetzwwges/anutzges
Qelnetzwwm2=Qelnetzwwges/anutzges
Qelueberschusswwm2=Qelueberschusswwges/anutzges
Qww_BedarfVerlustem2=QWW_gesm2+Qww_Speicherverlustm2
Qww_Deckungm2=QPVeigenm2+Qeigenwwwindm2+Qnetzwwm2
Qelww_Deckungm2=QelPVeigenm2+Qeleigenwwwindm2+Qelnetzwwm2

*48

Strom_ges=Qel*anutzges
Strom_PV=PVprod*anutzges
Q_Speichermax = 5000 !Wh
Q_Speicher_tminus1=[170,14]   !Speicherladung 1 Zeitschritt früher, type 93
Q_Speicher_t = lt(Strom_PV,Strom_ges)*(ge(Qmaxentladenstep,QbedarfminusPVStep)*(QSpeichertminus1incV-QbedarfminusPVStep/Ethaentladen)+(1-ge(Qmaxentladenstep,QbedarfminusPVStep))*0)+(1-lt(Strom_PV,Strom_ges))*(lt(QPVminusBedarfStep,Qmaxladenstep)*(QSpeichertminus1incV+QPVminusBedarfStep*Ethaladen)+(1-lt(QPVminusBedarfStep,Qmaxladenstep))*(Q_Speichermax))   !Wh, Ladezustand, bezogen auf maximale Entladbarkeit (d.h. 0-Niveau müssen nicht 0 Wh sein)
Q_AusNetz = lt(Strom_PV,Strom_ges)*(1-ge(Qmaxentladenstep,QbedarfminusPVStep))*((QbedarfminusPVStep-Qmaxentladenstep))/step  !Leistung, wird aus Netz bezogen
Q_UeberschussinsNetz = (1-lt(Strom_PV,Strom_ges))*(1-lt(QPVminusBedarfStep,deltaQmax1))*(QPVminusBedarf-Qmaxladen) !W Leistung, geht ins Netz
deltaQmax1 = Q_Speichermax-QSpeichertminus1incV   !Wh Energie
QSpeichertminus1incV = (1-EthaVerlusStep)*Q_Speicher_tminus1  !Wh Energie
EthaVerlust = 0.1 !%/100 Verlust pro Monat
EthaVerlusStep = EthaVerlust/720*step !%/100 Verlust pro Zeitschritt
QPVminusBedarf = (1-gt(Strom_ges,Strom_PV))*(Strom_PV-Strom_ges) !W Leistung
QBedarfminusPV = gt(Strom_ges,Strom_PV)*(Strom_ges-Strom_PV)  !W Leistung 
Ethaladen = 0.95  !%/100, bezogen auf die Energie, die in den Speicher eingespeist werden soll
Ethaentladen = 0.95  !%/100, bezogen auf die Energie, die dem Speicher entnommen wird  
QPVminusBedarfStep = QPVminusBedarf*step  !Energie Wh  
QbedarfminusPVStep = QBedarfminusPV*step !Energie Wh
Qmaxladenstep = deltaQmax1/Ethaladen   ! Wh max mögliche Energie nach Entladen aus Speicher
Qmaxladen = Qmaxladenstep/Step  !W Leistung
Qmaxentladenstep = QSpeichertminus1incV*Ethaentladen  !Wh Maximal entladbare Energie, bezogen auf bereitgestellte Energie
Qmaxentladen = Qmaxentladenstep/step
Qdeckeneigendir = lt(Strom_PV,Strom_ges)*Strom_PV   +(1-lt(Strom_PV,Strom_ges))*Strom_ges !W, Direktdeckung ohne Speicher
QUeberschussdir = lt(Strom_ges,Strom_PV)*(Strom_PV-Strom_ges)  !W Überschuss nach Direktdeckung vor Batterieladen
QdeckenEigenspeicher = lt(Strom_PV,Strom_ges)*(ge(Qmaxentladenstep,QbedarfminusPVStep)*(QbedarfminusPV)+(1-ge(Qmaxentladenstep,QbedarfminusPVStep))*Qmaxentladen)   !W
QVerlustSpeicher = (Q_Speicher_tminus1-QSpeichertminus1incV)/step  !W
QVerlustLaden = (1-lt(Strom_PV,Strom_ges))*(lt(QPVminusBedarfStep,Qmaxladenstep)*(QPVminusBedarf)*(1-Ethaladen)+(1-lt(QPVminusBedarfStep,Qmaxladenstep))*(Qmaxladen) *(1-Ethaladen))  !W  
QVerlustEntladen = lt(Strom_PV,Strom_ges)*(ge(Qmaxentladenstep,QbedarfminusPVStep)*(QbedarfminusPV/Ethaentladen)*(1-Ethaentladen)+(1-ge(Qmaxentladenstep,QbedarfminusPVStep))*Qmaxentladen/Ethaentladen*(1-Ethaentladen))  !W
Qdeckeneigendirm2 = Qdeckeneigendir/anutzges  !W/m2
QUeberschussdirm2 = QUeberschussdir/anutzges  !W/m2
QdeckenEigenspeicherm2 = QdeckenEigenspeicher/anutzges   !W/m2
Q_UeberschussinsNetzm2=Q_UeberschussinsNetz/anutzges
Q_Speicher_tm2=Q_Speicher_t/anutzges  !Wh/m2
Qverlustges=QVerlustSpeicher+QVerlustLaden+QVerlustEntladen
Qverlustgesm2=Qverlustges/anutzges
