* EQUATIONS "Klima"
* 
EQUATIONS 80
ta = (-4.8*heizperiode1+26.3*kuehlperiode1)*impuls+(1-impuls)*[109,1]
relha = (80*heizperiode1+65*kuehlperiode1)*impuls+(1-impuls)*[109,7]
absa = (0.003*heizperiode1+0.012*kuehlperiode1)*impuls+(1-impuls)*[109,6]
tsky = (ta-11)*impuls+(1-impuls)*[109,4]
tsgrd = ta
twasgrd = [109,5]
Ttau = [109,2]
Twetbaulb = [109,3]
* siehe oben   terd1 = 9.9+[19,2]*(20.7-9.9)  ! Bestand: 9.9+[19,2]*(20.7-9.9) OIB:6.1+[19,2]*(19.6-6.1)  NEH:  9.6+[19,2]*(16.3-9.6) PH: 10.4+[19,2]*(15.4-10.4)  !ta+(heizperiode1*21+26*(1-heizperiode1)-ta)/2 !9.5+[19,2]*15.1  !EG, Temperaturfaktor ca. 0.5
terd2 = 10 !11.04+[19,2]*16.4  !UG
terd3 = 10 !11.04+[19,2]*16.4
Tewtphpp = 7.1+[19,2]*7
GRD_REFL = 0.2  ! Sehr gefährlich, unbedingt Input checken[109,91]
wind = [109,8]
winddir = [109,9]
druck = [109,10]  !atm  !11
TURN = 0
HEMISPHERE = 1 ! northern hemisphere: 1  - southern hemisphere: -1
AA_H_0_0 = 0  ! azimuth angle of orientation
AA_S_0_90 = (0  +TURN)*GT(HEMISPHERE,0)+ (180-0 -TURN)*NOT(GT(HEMISPHERE,0)) ! azimuth angle of orientation
AA_W_90_90 = (90 +TURN)*GT(HEMISPHERE,0)+ (180-90-TURN)*NOT(GT(HEMISPHERE,0)) ! azimuth angle of orientation
AA_N_180_90 = (180+TURN)*GT(HEMISPHERE,0)+ (180-180-TURN)*NOT(GT(HEMISPHERE,0)) ! azimuth angle of orientation
AA_E_270_90 = (270+TURN)*GT(HEMISPHERE,0)+ (180-270-TURN)*NOT(GT(HEMISPHERE,0)) ! azimuth angle of orientation
AA_W2 = (90 +TURN)*GT(HEMISPHERE,0)+ (180-45-TURN)*NOT(GT(HEMISPHERE,0)) ! azimuth angle of orientation
AA_N2 = (180+TURN)*GT(HEMISPHERE,0)+ (180-135-TURN)*NOT(GT(HEMISPHERE,0)) ! azimuth angle of orientation
AA_E2 = (270+TURN)*GT(HEMISPHERE,0)+ (180-225-TURN)*NOT(GT(HEMISPHERE,0)) ! azimuth angle of orientation
AA_S2 = (0+TURN)*GT(HEMISPHERE,0)+ (180-315-TURN)*NOT(GT(HEMISPHERE,0)) ! azimuth angle of orientation
AAZM_CORR_HEM = AAZM*GT(HEMISPHERE,0) +  NOT(GT(HEMISPHERE,0))*((180-AAZM)*GT(AAZM,0)*LE(AAZM,180) + (-180-AAZM)*NOT(GT(AAZM,0)*LE(AAZM,180))) !solar azimuth corrected for southern hemisphere such that north=180, south=0, west =90, east=-90
AAZM_TYPE56 = (AAZM_CORR_HEM - TURN) ! solar azimuth corrected by building rotation - Input for Type 56 sun position for SHM and ISM
AZEN = [109,16]
AAZM = [109,17]
IDHkJ = (10*heizperiode1+350*kuehlperiode1)*impuls+(1-impuls)*[109,20]    !Sky diffuse radiation on the horizontal, impuls sommer 20% direkt
IGHkJ = (10*heizperiode1+350*kuehlperiode1)*impuls+(1-impuls)*[109,24]    !Total incident of radation orientation H_0_0
IBHkJ = (0*heizperiode1+0*kuehlperiode1)*impuls+(1-impuls)*[109,33]    !Beam incident of radation orientation H_0_0
AIH = [109,69]    !Incident angle of orientation H_0_0
IGSkJ = (10*heizperiode1+180*kuehlperiode1)*impuls+(1-impuls)*[109,25]
IBSkJ = (0*heizperiode1+0*kuehlperiode1)*impuls+(1-impuls)*[109,34]
AIS = [109,70]
IGWkJ = (5*heizperiode1+220*kuehlperiode1)*impuls+(1-impuls)*[109,26]
IBWkJ = (0*heizperiode1+0*kuehlperiode1)*impuls+(1-impuls)*[109,35]
AIW = [109,71]
IGNkJ = (5*heizperiode1+100*kuehlperiode1)*impuls+(1-impuls)*[109,27]
IBNkJ = (0*heizperiode1+0*kuehlperiode1)*impuls+(1-impuls)*[109,36]
AIN = [109,72]
IGOkJ = (5*heizperiode1+210*kuehlperiode1)*impuls+(1-impuls)*[109,28]
IBOkJ = (0*heizperiode1+0*kuehlperiode1)*impuls+(1-impuls)*[109,37]
AIO = [109,73]
IGS2kJ = [109,29]
IBS2kJ = [109,38]
AIS2 = [109,74]
IGW2kJ = [109,30]
IBW2kJ = [109,39]
AIW2 = [109,75]
IGN2kJ = [109,31]
IBN2kJ = [109,40]
AIN2 = [109,76]
IGO2kJ = [109,32]
IBO2kJ = [109,41]
AIO2 = [109,77]
hour_of_day = MOD(TIME,24)  !11+13+31=55
idh = IDhkJ/3.6
igh = IghkJ/3.6
ibh = IbhkJ/3.6
igs = IGSkJ/3.6
ibs = IBSkJ/3.6
igw = IGWkJ/3.6
ibw = IBWkJ/3.6
